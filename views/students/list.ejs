<!-- views/students/list.ejs — Shows all students in a table -->

<div class="d-flex justify-content-between align-items-center mb-3">
  <h3><i class="bi bi-people me-2"></i>Students</h3>
  <a href="/students/new" class="btn btn-primary btn-sm">
    <i class="bi bi-person-plus me-1"></i>Add Student
  </a>
</div>

<% if (students.length === 0) { %>
  <div class="alert alert-info">
    No students registered yet. <a href="/students/new">Add one!</a>
  </div>
<% } else { %>
  <div class="table-responsive">
    <table class="table table-hover table-bordered align-middle">
      <thead class="table-primary">
        <tr>
          <th>#</th>
          <th>Name</th>
          <th>Email</th>
          <th>Department</th>
          <th>Semester</th>
          <th>Registered</th>
          <th class="text-center">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% students.forEach((s, i) => { %>
          <tr>
            <td class="text-muted small"><%= i + 1 %></td>
            <td><a href="/students/<%= s.student_id %>" class="text-decoration-none fw-semibold"><%= s.name %></a></td>
            <td><%= s.email %></td>
            <td><span class="badge bg-light text-dark border"><%= s.department %></span></td>
            <td class="text-center"><%= s.semester %></td>
            <td class="text-muted small"><%= new Date(s.created_at).toLocaleDateString('en-GB') %></td>
            <td class="text-center">
              <a href="/students/<%= s.student_id %>" class="btn btn-sm btn-outline-secondary me-1" title="View">
                <i class="bi bi-eye"></i>
              </a>
              <a href="/students/<%= s.student_id %>/edit" class="btn btn-sm btn-outline-primary me-1" title="Edit">
                <i class="bi bi-pencil"></i>
              </a>
              <!-- DELETE via hidden form (method-override) -->
              <form action="/students/<%= s.student_id %>?_method=DELETE" method="POST" class="d-inline"
                    onsubmit="return confirm('Delete <%= s.name %>? This will also remove their applications.')">
                <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                  <i class="bi bi-trash"></i>
                </button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <p class="text-muted small mt-1"><%= students.length %> student(s) total.</p>
<% } %>
