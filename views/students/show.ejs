<!-- views/students/show.ejs — Student profile page -->

<div class="d-flex justify-content-between align-items-start mb-3">
  <div>
    <h3><i class="bi bi-person-circle me-2"></i><%= student.name %></h3>
    <p class="text-muted mb-0">Student Profile</p>
  </div>
  <div>
    <a href="/students/<%= student.student_id %>/edit" class="btn btn-outline-primary btn-sm me-1">
      <i class="bi bi-pencil me-1"></i>Edit
    </a>
    <a href="/students" class="btn btn-outline-secondary btn-sm">
      <i class="bi bi-arrow-left me-1"></i>Back
    </a>
  </div>
</div>

<!-- Profile card -->
<div class="card shadow-sm border-0 mb-4">
  <div class="card-body">
    <div class="row g-3">
      <div class="col-md-6">
        <label class="text-muted small fw-semibold text-uppercase">Email</label>
        <p class="mb-0"><%= student.email %></p>
      </div>
      <div class="col-md-3">
        <label class="text-muted small fw-semibold text-uppercase">Department</label>
        <p class="mb-0"><span class="badge bg-primary"><%= student.department %></span></p>
      </div>
      <div class="col-md-3">
        <label class="text-muted small fw-semibold text-uppercase">Semester</label>
        <p class="mb-0"><%= student.semester %></p>
      </div>
      <div class="col-md-6">
        <label class="text-muted small fw-semibold text-uppercase">Registered</label>
        <p class="mb-0 text-muted small">
          <%= new Date(student.created_at).toLocaleString('en-GB') %>
        </p>
      </div>
    </div>
  </div>
</div>

<!-- Applications — result of sp_get_student_applications() stored procedure -->
<h5 class="mb-3"><i class="bi bi-file-earmark-text me-1"></i>Applications
  <span class="badge bg-secondary ms-1"><%= applications.length %></span>
</h5>

<% if (applications.length === 0) { %>
  <div class="alert alert-light">This student has not applied for any jobs yet.</div>
<% } else { %>
  <div class="table-responsive">
    <table class="table table-sm table-hover table-bordered align-middle">
      <thead class="table-light">
        <tr>
          <th>Job Title</th>
          <th>Company</th>
          <th>Applied On</th>
          <th>Status</th>
          <th class="text-center">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% applications.forEach(app => { %>
          <tr>
            <td>
              <a href="/jobs/<%= app.job_id %>" class="text-decoration-none"><%= app.job_title %></a>
            </td>
            <td><%= app.company_name %></td>
            <td class="text-muted small"><%= new Date(app.application_date).toLocaleDateString('en-GB', { timeZone: 'UTC' }) %></td>
            <td>
              <span class="badge jn-badge-<%= app.application_status.toLowerCase() %>">
                <%= app.application_status %>
              </span>
            </td>
            <td class="text-center">
              <a href="/applications/<%= app.application_id %>/edit" class="btn btn-xs btn-outline-primary me-1">
                <i class="bi bi-pencil"></i>
              </a>
              <form action="/applications/<%= app.application_id %>?_method=DELETE" method="POST"
                    class="d-inline"
                    onsubmit="return confirm('Withdraw this application?')">
                <button type="submit" class="btn btn-xs btn-outline-danger">
                  <i class="bi bi-trash"></i>
                </button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
<% } %>

<a href="/applications/new" class="btn btn-sm btn-success mt-2">
  <i class="bi bi-send-plus me-1"></i>Submit New Application
</a>
