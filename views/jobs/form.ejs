<!-- views/jobs/form.ejs — Post / Edit job (shared form) -->

<div class="d-flex justify-content-between align-items-center mb-3">
  <h3>
    <i class="bi bi-<%= job.job_id ? 'pencil-square' : 'plus-circle' %> me-2"></i><%= title %>
  </h3>
  <a href="/jobs" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left me-1"></i>Back
  </a>
</div>

<%- include('../partials/errors') %>

<% if (companies.length === 0) { %>
  <div class="alert alert-warning">
    <i class="bi bi-exclamation-triangle me-1"></i>
    No companies registered yet.
    <a href="/companies/new" class="alert-link">Register a company first</a>, then post a job.
  </div>
<% } else { %>
<div class="card shadow-sm border-0">
  <div class="card-body">
    <form action="<%= formAction %>" method="POST" novalidate>

      <div class="mb-3">
        <label for="company_id" class="form-label fw-semibold">
          Company <span class="text-danger">*</span>
        </label>
        <select id="company_id" name="company_id" class="form-select" required>
          <option value="">— Select company —</option>
          <% companies.forEach(c => { %>
            <option
              value="<%= c.company_id %>"
              <%= String(job.company_id) === String(c.company_id) ? 'selected' : '' %>
            >
              <%= c.company_name %>
            </option>
          <% }); %>
        </select>
      </div>

      <div class="mb-3">
        <label for="title" class="form-label fw-semibold">
          Job Title <span class="text-danger">*</span>
        </label>
        <input
          type="text"
          id="title"
          name="title"
          class="form-control"
          value="<%= job.title || '' %>"
          placeholder="e.g. Backend Developer Intern"
          maxlength="150"
          required
        />
      </div>

      <div class="mb-3">
        <label for="description" class="form-label fw-semibold">Description</label>
        <textarea
          id="description"
          name="description"
          class="form-control"
          rows="4"
          placeholder="Describe the role, responsibilities, and requirements..."
        ><%= job.description || '' %></textarea>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-md-4">
          <label for="salary" class="form-label fw-semibold">Monthly Salary (BDT)</label>
          <input
            type="number"
            id="salary"
            name="salary"
            class="form-control"
            value="<%= job.salary || '' %>"
            placeholder="e.g. 15000"
            min="1"
            step="500"
          />
          <div class="form-text">Leave blank if unpaid / TBD.</div>
        </div>

        <div class="col-md-4">
          <label for="deadline" class="form-label fw-semibold">
            Application Deadline <span class="text-danger">*</span>
          </label>
          <input
            type="date"
            id="deadline"
            name="deadline"
            class="form-control"
            value="<%= job.deadline ? String(job.deadline).substring(0, 10) : '' %>"
            required
          />
        </div>

        <% if (job.job_id) { %>
        <div class="col-md-4">
          <label for="status" class="form-label fw-semibold">Status</label>
          <select id="status" name="status" class="form-select">
            <option value="Open"   <%= job.status === 'Open'   ? 'selected' : '' %>>Open</option>
            <option value="Closed" <%= job.status === 'Closed' ? 'selected' : '' %>>Closed</option>
          </select>
        </div>
        <% } %>
      </div>

      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-warning text-dark">
          <i class="bi bi-check-lg me-1"></i>
          <%= job.job_id ? 'Update Job' : 'Post Job' %>
        </button>
        <a href="/jobs" class="btn btn-outline-secondary">Cancel</a>
      </div>

    </form>
  </div>
</div>
<% } %>
