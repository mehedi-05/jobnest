<div class="d-flex justify-content-between align-items-center mb-3">
  <h3>
    <i class="bi bi-<%= application.application_id ? 'pencil-square' : 'send-plus' %> me-2"></i>
    <%= title %>
  </h3>
  <a href="/applications" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left me-1"></i>Back
  </a>
</div>

<%- include('../partials/errors') %>

<div class="card shadow-sm border-0">
  <div class="card-body">
    <form action="<%= formAction %>" method="POST" novalidate>

      <% if (application.application_id) { %>
        <!-- ── EDIT MODE: show read-only info + status selector ── -->
        <div class="alert alert-light mb-4">
          <div class="row g-2">
            <div class="col-md-6">
              <span class="text-muted small fw-semibold text-uppercase">Student</span>
              <p class="mb-0 fw-semibold"><%= application.student_name %></p>
              <p class="mb-0 text-muted small"><%= application.student_email %></p>
            </div>
            <div class="col-md-6">
              <span class="text-muted small fw-semibold text-uppercase">Job</span>
              <p class="mb-0 fw-semibold"><%= application.job_title %></p>
              <p class="mb-0 text-muted small"><%= application.company_name %></p>
            </div>
          </div>
        </div>

        <div class="mb-4">
          <label for="status" class="form-label fw-semibold">
            Application Status <span class="text-danger">*</span>
          </label>
          <select id="status" name="status" class="form-select" required>
            <% statuses.forEach(s => { %>
              <option
                value="<%= s %>"
                <%= application.application_status === s ? 'selected' : '' %>
              ><%= s %></option>
            <% }); %>
          </select>
          <div class="form-text">Allowed values: Pending, Reviewed, Accepted, Rejected.</div>
        </div>

      <% } else { %>
        <!-- ── CREATE MODE: choose student + job ── -->

        <% if (jobs.length === 0) { %>
          <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-1"></i>
            No open jobs available to apply for. Check back later or
            <a href="/jobs/new" class="alert-link">post a job</a>.
          </div>
        <% } else if (students.length === 0) { %>
          <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-1"></i>
            No students registered yet.
            <a href="/students/new" class="alert-link">Add a student first</a>.
          </div>
        <% } else { %>

          <div class="mb-3">
            <label for="student_id" class="form-label fw-semibold">
              Student <span class="text-danger">*</span>
            </label>
            <select id="student_id" name="student_id" class="form-select" required>
              <option value="">— Select student —</option>
              <% students.forEach(s => { %>
                <option
                  value="<%= s.student_id %>"
                  <%= String(application.student_id) === String(s.student_id) ? 'selected' : '' %>
                >
                  <%= s.name %> (<%= s.email %>)
                </option>
              <% }); %>
            </select>
          </div>

          <div class="mb-4">
            <label for="job_id" class="form-label fw-semibold">
              Job <span class="text-danger">*</span>
            </label>
            <select id="job_id" name="job_id" class="form-select" required>
              <option value="">— Select open job —</option>
              <% jobs.forEach(j => { %>
                <option
                  value="<%= j.job_id %>"
                  <%= String(application.job_id) === String(j.job_id) ? 'selected' : '' %>
                >
                  <%= j.title %> — <%= j.company_name %>
                </option>
              <% }); %>
            </select>
            <div class="form-text">Only open jobs with a future deadline are shown.</div>
          </div>

        <% } %>
      <% } %>

      <% const canSubmit = application.application_id || (jobs.length > 0 && students.length > 0); %>
      <% if (canSubmit) { %>
        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-danger">
            <i class="bi bi-check-lg me-1"></i>
            <%= application.application_id ? 'Update Status' : 'Submit Application' %>
          </button>
          <a href="/applications" class="btn btn-outline-secondary">Cancel</a>
        </div>
      <% } %>

    </form>
  </div>
</div>
