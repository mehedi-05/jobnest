<!-- views/error.ejs — generic error page -->
<div class="text-center py-5">
  <div class="display-1 text-muted fw-bold"><%= typeof status !== 'undefined' ? status : 500 %></div>
  <h2 class="mt-2 mb-3"><%= title || 'Error' %></h2>
  <p class="text-muted mb-4"><%= message || 'Something went wrong.' %></p>
  <a href="/" class="btn btn-primary">
    <i class="bi bi-house-door me-1"></i>Back to Dashboard
  </a>
</div>
