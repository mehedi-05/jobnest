<!-- views/companies/show.ejs — Company profile + their job listings -->

<div class="d-flex justify-content-between align-items-start mb-3">
  <div>
    <h3><i class="bi bi-building me-2 text-success"></i><%= company.company_name %></h3>
    <p class="text-muted mb-0">Company Profile</p>
  </div>
  <div>
    <a href="/companies/<%= company.company_id %>/edit" class="btn btn-outline-primary btn-sm me-1">
      <i class="bi bi-pencil me-1"></i>Edit
    </a>
    <a href="/companies" class="btn btn-outline-secondary btn-sm">
      <i class="bi bi-arrow-left me-1"></i>Back
    </a>
  </div>
</div>

<!-- Company detail card -->
<div class="card shadow-sm border-0 mb-4">
  <div class="card-body">
    <div class="row g-3">
      <div class="col-md-4">
        <label class="text-muted small fw-semibold text-uppercase">Email</label>
        <p class="mb-0"><i class="bi bi-envelope me-1"></i><%= company.email %></p>
      </div>
      <div class="col-md-4">
        <label class="text-muted small fw-semibold text-uppercase">Location</label>
        <p class="mb-0"><i class="bi bi-geo-alt me-1"></i><%= company.location %></p>
      </div>
      <div class="col-md-4">
        <label class="text-muted small fw-semibold text-uppercase">Registered</label>
        <p class="mb-0 text-muted small">
          <%= new Date(company.created_at).toLocaleDateString('en-GB') %>
        </p>
      </div>
    </div>
  </div>
</div>

<!-- Jobs posted by this company -->
<div class="d-flex justify-content-between align-items-center mb-3">
  <h5 class="mb-0">
    <i class="bi bi-bag-check me-1"></i>Job Listings
    <span class="badge bg-secondary ms-1"><%= jobs.length %></span>
  </h5>
  <a href="/jobs/new" class="btn btn-sm btn-outline-success">
    <i class="bi bi-plus-circle me-1"></i>Post New Job
  </a>
</div>

<% if (jobs.length === 0) { %>
  <div class="alert alert-light">This company has not posted any jobs yet.</div>
<% } else { %>
  <div class="table-responsive">
    <table class="table table-sm table-hover table-bordered align-middle">
      <thead class="table-light">
        <tr>
          <th>Title</th>
          <th class="text-center">Status</th>
          <th>Deadline</th>
          <th>Salary</th>
          <th class="text-center">Applicants</th>
          <th class="text-center">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% jobs.forEach(job => { %>
          <tr>
            <td>
              <a href="/jobs/<%= job.job_id %>" class="text-decoration-none fw-semibold"><%= job.title %></a>
            </td>
            <td class="text-center">
              <span class="badge bg-<%= job.status === 'Open' ? 'success' : 'secondary' %>">
                <%= job.status %>
              </span>
            </td>
            <td class="text-muted small">
              <%= new Date(job.deadline).toLocaleDateString('en-GB', { timeZone: 'UTC' }) %>
            </td>
            <td>
              <% if (job.salary) { %>
                ৳ <%= Number(job.salary).toLocaleString() %>
              <% } else { %>
                <span class="text-muted">—</span>
              <% } %>
            </td>
            <td class="text-center">
              <span class="badge bg-info text-dark"><%= job.applicant_count %></span>
            </td>
            <td class="text-center">
              <a href="/jobs/<%= job.job_id %>/edit" class="btn btn-xs btn-outline-primary me-1">
                <i class="bi bi-pencil"></i>
              </a>
              <form action="/jobs/<%= job.job_id %>?_method=DELETE" method="POST" class="d-inline"
                    onsubmit="return confirm('Delete this job and all its applications?')">
                <button type="submit" class="btn btn-xs btn-outline-danger">
                  <i class="bi bi-trash"></i>
                </button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
<% } %>
